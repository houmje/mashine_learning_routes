from sklearn.ensemble import RandomForestRegressor
from sklearn.inspection import permutation_importance

# Модель: Random Forest для предсказания расхода
rf = RandomForestRegressor(n_estimators=50, max_depth=10, n_jobs=-1)
rf.fit(X, y)  # X — признаки, y — consumption_kwh_per_100km

# Permutation importance: перемешиваем значения признака, смотрим падение качества
perm_importance = permutation_importance(rf, X, y, n_repeats=5, n_jobs=-1)

# Результат: чем выше importance, тем важнее признак
feature_imp = pd.DataFrame({
    'Feature': features,
    'Importance': perm_importance.importances_mean
}).sort_values(by='Importance', ascending=False)
